{
  "name": "atlas",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source CMDB for modern IT teams",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "migrate": "knex migrate:latest --knexfile db/knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile db/knexfile.js",
    "seed": "knex seed:run --knexfile db/knexfile.js",
    "db:setup": "node db/setup.js",
    "db:init": "node db/init.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@xyflow/react": "^12.11.0",
    "bcryptjs": "^3.0.3",
