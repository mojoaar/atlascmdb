    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "openid-client": "^6.8.4",
    "otpauth": "^9.5.1",
    "prismjs": "^1.30.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/leaflet": "^1.9.21",
    "@vitejs/plugin-react": "^6.0.2",
