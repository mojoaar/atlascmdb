# Database — SQLite (dev, default) uses the file path below.
# DATABASE_URL is only read for PostgreSQL (production); leave unset for dev SQLite.
# DATABASE_URL=postgres://user:password@localhost:5432/atlas

# App Environment
NODE_ENV=development

# JWT Authentication
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MFA Configuration
MFA_ISSUER=Atlas
